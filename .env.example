DATABASE_URL=postgresql://admin:secret@localhost:5432/mental_health
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
QDRANT_HOST=localhost
QDRANT_PORT=6333
INFERENCE_URL=
USE_MOCK_INFERENCE=true

# 默认走本机 Ollama；留空或删行时仍默认为 http://127.0.0.1:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=llama3.2:1b
OLLAMA_EMBED_MODEL=nomic-embed-text

# RAG：非空则检索 Qdrant；无库时可先留空
QDRANT_RAG_COLLECTION=
QDRANT_RAG_TOP_K=3

# 仅当 Ollama 不可用时回退关键词模板（本地跑 E2E 且无 Ollama 时可设为 true）
USE_TEMPLATE_FALLBACK=false
