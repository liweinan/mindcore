DATABASE_URL=postgresql://admin:secret@localhost:5432/mental_health
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
QDRANT_HOST=localhost
QDRANT_PORT=6333

# 默认走本机 Ollama；留空或删行时仍默认为 http://127.0.0.1:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434
# 默认最小常用组合：0.5B + q2_K；可改为 qwen2.5:0.5b-instruct 等（须 ollama pull）
OLLAMA_CHAT_MODEL=qwen2.5:0.5b-instruct-q2_K
OLLAMA_EMBED_MODEL=nomic-embed-text

# RAG：必填；须与 scripts/build_rag_knowledge.py 写入的集合名一致，且嵌入模型一致
QDRANT_RAG_COLLECTION=mental_health_knowledge
QDRANT_RAG_TOP_K=3

# 为 true 时打印 RAG 嵌入向量、Qdrant 命中、发往 Ollama 的 chat 请求 JSON（含用户正文，仅排障）
INFERENCE_DEBUG_LOG=true
