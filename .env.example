DATABASE_URL=postgresql://admin:secret@localhost:5432/mental_health
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
QDRANT_HOST=localhost
QDRANT_PORT=6333
INFERENCE_URL=
USE_MOCK_INFERENCE=true

# 本地 Ollama（ARM Mac 推荐装在本机，Metal 加速；API 在宿主机跑时用 http://127.0.0.1:11434）
OLLAMA_BASE_URL=
OLLAMA_CHAT_MODEL=qwen2.5:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# RAG：与 Qdrant 集合名一致；写入前请用 Ollama 嵌入重建库（见 README）
QDRANT_RAG_COLLECTION=mental_health_knowledge
QDRANT_RAG_TOP_K=3
